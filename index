<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Agency Finance">
    <title>Agency Finances</title>
    <style>
        :root { --bg: #000000; --card: #1c1c1e; --text: #ffffff; --accent: #0a84ff; --danger: #ff453a; --success: #32d74b; --warning: #ffd60a; --purple: #bf5af2; --muted: #8e8e93;}
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; padding-bottom: 90px; }
        .container { padding: 20px; }
        .card { background: var(--card); border-radius: 16px; padding: 20px; margin-bottom: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        h2 { margin-top: 0; font-size: 1.2em; color: var(--muted); font-weight: 500;}
        h3 { font-size: 1em; color: white; margin-bottom: 10px; margin-top: 20px;}
        
        /* Auth Screen */
        #auth-screen { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: var(--bg); z-index: 999; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; }
        .pin-display { font-size: 2em; letter-spacing: 10px; margin-bottom: 20px; height: 40px; }
        .keypad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; max-width: 300px; width: 100%; }
        .key { background: #2c2c2e; border-radius: 50%; width: 70px; height: 70px; display: flex; justify-content: center; align-items: center; font-size: 1.5em; font-weight: bold; margin: auto; cursor: pointer; }
        
        /* Header / Stats */
        .header-stats { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .stat-block { background: #2c2c2e; padding: 12px; border-radius: 12px; flex: 1; margin: 0 5px; text-align: center; }
        .stat-label { font-size: 0.75em; color: var(--muted); text-transform: uppercase; }
        .stat-value { font-size: 1.2em; font-weight: bold; color: var(--success); margin-top: 4px; }
        
        /* Calendar */
        .cal-header { text-align: center; font-weight: bold; margin-bottom: 10px; font-size: 1.1em; display: flex; justify-content: space-between; align-items: center;}
        .cal-btn { background: transparent; color: var(--accent); border: none; font-size: 1.2em; cursor: pointer; padding: 5px 15px; }
        .cal-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; text-align: center; font-size: 0.8em; color: var(--muted); margin-bottom: 5px; }
        .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; margin-bottom: 15px;}
        .cal-cell { background: #2c2c2e; border-radius: 8px; padding: 10px 0 16px 0; text-align: center; font-size: 0.9em; position: relative; cursor: pointer;}
        .cal-cell.empty { background: transparent; }
        .cal-cell.today { background: #48484a; color: white; font-weight: bold; border: 1px solid var(--accent); }
        .cal-cell.has-event { border-bottom: 3px solid var(--accent); }

        /* Timeline Items */
        .list-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #38383a; padding: 15px 0; }
        .list-item:last-child { border-bottom: none; }
        .item-details { flex-grow: 1; }
        .item-title { font-weight: bold; font-size: 1.1em; display: flex; align-items: center; gap: 5px;}
        .item-sub { font-size: 0.85em; color: var(--muted); margin-top: 4px; display: flex; flex-direction: column; gap: 2px;}
        .price-eur { font-weight: bold; font-size: 1.1em; color: white; text-align: right;}
        .price-usd { font-size: 0.8em; color: var(--muted); text-align: right;}
        .badge { background: #38383a; padding: 3px 6px; border-radius: 4px; font-size: 0.75em; color: var(--accent); margin-left: 5px; font-weight: bold;}
        .badge-annual { color: var(--purple); }
        
        /* Form Inputs */
        label { font-size: 0.9em; color: var(--muted); margin-bottom: 5px; display: block; }
        input, select, button { width: 100%; padding: 16px; margin-bottom: 15px; border-radius: 12px; border: none; font-size: 16px; box-sizing: border-box; background: #2c2c2e; color: white; font-family: inherit;}
        button { background: var(--accent); color: white; font-weight: bold; cursor: pointer; }
        .btn-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); padding: 8px; font-size: 0.9em;}
        .checkbox-wrapper { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; background: #2c2c2e; padding: 15px; border-radius: 12px; }
        
        /* Loading Overlay */
        #loader { display: none; text-align: center; padding: 20px; color: var(--accent); font-weight: bold; }
        
        /* Navigation */
        .nav { display: flex; justify-content: space-around; position: fixed; bottom: 0; left: 0; right: 0; background: rgba(28, 28, 30, 0.9); backdrop-filter: blur(10px); padding: 15px 2px 25px 2px; border-top: 1px solid #38383a; z-index: 100;}
        .nav div { color: var(--accent); font-size: 0.8em; font-weight: 600; cursor: pointer; padding: 8px 5px; text-align: center; flex: 1;}
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div id="auth-screen">
        <h2 style="color: white; margin-bottom: 10px;">Agency Login</h2>
        <div id="pin-display" class="pin-display"></div>
        <div class="keypad">
            <div class="key" onclick="enterPin(1)">1</div><div class="key" onclick="enterPin(2)">2</div><div class="key" onclick="enterPin(3)">3</div>
            <div class="key" onclick="enterPin(4)">4</div><div class="key" onclick="enterPin(5)">5</div><div class="key" onclick="enterPin(6)">6</div>
            <div class="key" onclick="enterPin(7)">7</div><div class="key" onclick="enterPin(8)">8</div><div class="key" onclick="enterPin(9)">9</div>
            <div class="key" style="background:transparent;" onclick="clearPin()">C</div><div class="key" onclick="enterPin(0)">0</div><div class="key" style="background:transparent;"></div>
        </div>
    </div>

    <div id="view-calendar" class="container hidden">
        <div class="header-stats">
            <div class="stat-block">
                <div class="stat-label">Upcoming (30 Days)</div>
                <div id="stat-upcoming" class="stat-value">0.00 €</div>
            </div>
            <div class="stat-block">
                <div class="stat-label">Total MRR (Est.)</div>
                <div id="stat-mrr" class="stat-value" style="color: var(--purple);">0.00 €</div>
            </div>
        </div>

        <div class="card">
            <div class="cal-header">
                <button class="cal-btn" onclick="changeMonth(-1)">‹</button>
                <span id="cal-month-title">Month</span>
                <button class="cal-btn" onclick="changeMonth(1)">›</button>
            </div>
            <div class="cal-days">
                <div>S</div><div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div>
            </div>
            <div id="calendar-grid" class="cal-grid"></div>
        </div>

        <div id="loader">Syncing with Google Drive...</div>

        <div class="card">
            <h2>Timeline <span id="timeline-month-label"></span></h2>
            <div id="timeline-list"></div>
        </div>
    </div>

    <div id="view-add" class="container hidden">
        <div class="card">
            <h2>Add / Manage Webflow Hosting</h2>
            <form id="add-client-form">
                <label>Client / Project Name</label>
                <input type="text" id="add-name" required placeholder="e.g. Acme Corp">
                
                <label>Webflow Plan</label>
                <select id="add-plan">
                    <option value="Basic">Basic Site</option>
                    <option value="CMS" selected>CMS Site</option>
                </select>

                <label>Billing Cycle</label>
                <select id="add-cycle">
                    <option value="monthly">Monthly</option>
                    <option value="annual">Annual (Discounted)</option>
                </select>

                <label>Next Renewal Date</label>
                <input type="date" id="add-date" required>
                
                <button type="submit">Save to Database</button>
            </form>
        </div>
    </div>

    <div id="view-settings" class="container hidden">
        <div class="card">
            <h2>Pricing & VAT Settings</h2>
            
            <div class="checkbox-wrapper">
                <span>Display Prices with VAT</span>
                <input type="checkbox" id="set-vat-toggle" onchange="updateSettings()" style="width: auto; margin:0;">
            </div>
            
            <label>VAT Rate (%)</label>
            <input type="number" id="set-vat-rate" value="20" onchange="updateSettings()">
            
            <label>USD to EUR Exchange Rate</label>
            <input type="number" step="0.01" id="set-usd-eur" value="0.92" onchange="updateSettings()">
            <p style="font-size: 0.8em; color: var(--muted);">Webflow bills in USD. We calculate the EUR equivalent using this rate.</p>
            
            <button class="btn-outline" onclick="fetchData()">Force Force Reload Database</button>
        </div>
    </div>

    <div class="nav hidden" id="bottom-nav">
        <div onclick="switchView('calendar')">📅 Calendar</div>
        <div onclick="switchView('add')">➕ Add Client</div>
        <div onclick="switchView('settings')">⚙️ Settings</div>
    </div>

    <script>
        // --- APP CONFIG ---
        const API_URL = "https://script.google.com/macros/s/AKfycbzyWVxoBOVF5vDC3GxILhSSLuGX3a7ku8yTr-ejio9g7yguO144heqwELsk-Sw3fDOJ8A/exec";
        const CORRECT_PIN = "1234"; // Tell your boss this PIN!
        
        let clients = [];
        let currentMonth = new Date().getMonth();
        let currentYear = new Date().getFullYear();
        
        let settings = JSON.parse(localStorage.getItem('agency_settings')) || {
            showVat: false,
            vatRate: 20,
            usdToEur: 0.92
        };

        // --- AUTH LOGIC ---
        let pinAttempt = "";
        function enterPin(num) {
            if(pinAttempt.length < 4) {
                pinAttempt += num;
                document.getElementById('pin-display').innerText = "• ".repeat(pinAttempt.length);
                if(pinAttempt.length === 4) verifyPin();
            }
        }
        function clearPin() {
            pinAttempt = "";
            document.getElementById('pin-display').innerText = "";
        }
        function verifyPin() {
            if(pinAttempt === CORRECT_PIN) {
                document.getElementById('auth-screen').classList.add('hidden');
                document.getElementById('bottom-nav').classList.remove('hidden');
                initApp();
            } else {
                document.getElementById('pin-display').innerText = "❌";
                setTimeout(clearPin, 800);
            }
        }

        // --- PRICING ENGINE ---
        function calculatePrices(plan, cycle) {
            let usdPrice = 0;
            if (plan === "CMS") {
                usdPrice = cycle === "monthly" ? 29 : 276; // 23 * 12
            } else if (plan === "Basic") {
                usdPrice = cycle === "monthly" ? 18 : 168; // 14 * 12
            }
            
            let eurPrice = usdPrice * settings.usdToEur;
            
            if (settings.showVat) {
                eurPrice = eurPrice * (1 + (settings.vatRate / 100));
            }
            
            return { usd: usdPrice, eur: eurPrice };
        }

        // --- INIT & FETCH ---
        function initApp() {
            document.getElementById('set-vat-toggle').checked = settings.showVat;
            document.getElementById('set-vat-rate').value = settings.vatRate;
            document.getElementById('set-usd-eur').value = settings.usdToEur;
            
            switchView('calendar');
            fetchData();
        }

        function updateSettings() {
            settings.showVat = document.getElementById('set-vat-toggle').checked;
            settings.vatRate = parseFloat(document.getElementById('set-vat-rate').value) || 20;
            settings.usdToEur = parseFloat(document.getElementById('set-usd-eur').value) || 0.92;
            localStorage.setItem('agency_settings', JSON.stringify(settings));
            renderTimeline(); 
        }

        async function fetchData() {
            document.getElementById('loader').style.display = 'block';
            try {
                const response = await fetch(API_URL);
                const json = await response.json();
                if (json.status === "success") {
                    clients = json.data;
                    renderCalendar();
                    renderTimeline();
                }
            } catch (err) {
                alert("Error connecting to Google Sheets. Check your connection.");
            }
            document.getElementById('loader').style.display = 'none';
        }

        // --- CALENDAR & TIMELINE ---
        function changeMonth(dir) {
            currentMonth += dir;
            if (currentMonth > 11) { currentMonth = 0; currentYear++; }
            if (currentMonth < 0) { currentMonth = 11; currentYear--; }
            renderCalendar();
            renderTimeline();
        }

        function renderCalendar() {
            const date = new Date(currentYear, currentMonth, 1);
            document.getElementById('cal-month-title').textContent = date.toLocaleDateString(undefined, { month: 'long', year: 'numeric' });
            document.getElementById('timeline-month-label').textContent = `- ${date.toLocaleDateString(undefined, { month: 'short' })}`;
            
            const firstDay = date.getDay();
            const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            const grid = document.getElementById('calendar-grid');
            grid.innerHTML = '';
            
            for(let i = 0; i < firstDay; i++) grid.innerHTML += `<div class="cal-cell empty"></div>`;
            
            for(let i = 1; i <= daysInMonth; i++) {
                let cellDate = new Date(currentYear, currentMonth, i).toISOString().split('T')[0];
                let todayStr = new Date().toISOString().split('T')[0];
                
                let isToday = cellDate === todayStr ? 'today' : '';
                let hasEvent = clients.some(c => c.NextRenewal && c.NextRenewal.startsWith(cellDate)) ? 'has-event' : '';
                
                grid.innerHTML += `<div class="cal-cell ${isToday} ${hasEvent}">${i}</div>`;
            }
        }

        function renderTimeline() {
            const list = document.getElementById('timeline-list');
            list.innerHTML = '';
            
            let upcomingTotal = 0;
            let mrrEst = 0;

            // Sort clients by date
            const sortedClients = [...clients].sort((a, b) => new Date(a.NextRenewal) - new Date(b.NextRenewal));

            sortedClients.forEach(client => {
                if (!client.NextRenewal) return;
                
                let d = new Date(client.NextRenewal);
                const prices = calculatePrices(client.PlanType, client.BillingCycle);
                
                // Calculate Stats
                let timeDiff = (d - new Date()) / (1000 * 3600 * 24);
                if (timeDiff >= 0 && timeDiff <= 30) upcomingTotal += prices.eur;
                
                if (client.BillingCycle === "monthly") mrrEst += prices.eur;
                if (client.BillingCycle === "annual") mrrEst += (prices.eur / 12);

                // Filter for current month view
                if (d.getMonth() === currentMonth && d.getFullYear() === currentYear) {
                    let div = document.createElement('div');
                    div.className = 'list-item';
                    
                    let dateStr = d.toLocaleDateString(undefined, { day: 'numeric', month: 'short' });
                    let cycleBadge = client.BillingCycle === 'annual' ? '<span class="badge badge-annual">Yearly</span>' : '<span class="badge">Monthly</span>';
                    
                    let invoiceBtn = client.InvoiceURL 
                        ? `<a href="${client.InvoiceURL}" target="_blank" class="btn-outline" style="text-decoration:none; display:inline-block; margin-top:5px; font-size:0.7em;">📄 View Invoice</a>`
                        : `<button class="btn-outline" style="margin-top:5px; font-size:0.7em; width:auto; padding: 4px 8px;" onclick="alert('Upload feature requires file picker logic in JS, ready to add next!')">⬆️ Add Invoice</button>`;

                    div.innerHTML = `
                        <div class="item-details">
                            <div class="item-title">${client.ClientName}</div>
                            <div class="item-sub">
                                <span>🗓 ${dateStr} | ${client.PlanType} ${cycleBadge}</span>
                                ${invoiceBtn}
                            </div>
                        </div>
                        <div>
                            <div class="price-eur">${prices.eur.toFixed(2)} €</div>
                            <div class="price-usd">$${prices.usd} ${settings.showVat ? '+ VAT' : ''}</div>
                        </div>
                    `;
                    list.appendChild(div);
                }
            });
            
            document.getElementById('stat-upcoming').textContent = upcomingTotal.toFixed(2) + ' €';
            document.getElementById('stat-mrr').textContent = mrrEst.toFixed(2) + ' €';
        }

        // --- FORMS (POST TO BACKEND) ---
        document.getElementById('add-client-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = this.querySelector('button');
            btn.textContent = "Saving...";
            
            const payload = {
                action: "add_subscription",
                data: {
                    clientName: document.getElementById('add-name').value,
                    planType: document.getElementById('add-plan').value,
                    billingCycle: document.getElementById('add-cycle').value,
                    startDate: new Date().toISOString().split('T')[0],
                    nextRenewal: document.getElementById('add-date').value,
                    priceUSD: 0, // Backend or pricing engine handles this conceptually, but we can pass 0 for now
                    priceEUR: 0
                }
            };

            try {
                await fetch(API_URL, {
                    method: 'POST',
                    body: JSON.stringify(payload)
                });
                alert("Saved to Google Sheets!");
                this.reset();
                fetchData(); // Refresh calendar
                switchView('calendar');
            } catch (err) {
                alert("Failed to save. " + err);
            }
            btn.textContent = "Save to Database";
        });

        // --- NAVIGATION ---
        function switchView(view) {
            ['calendar', 'add', 'settings'].forEach(v => {
                document.getElementById('view-' + v).classList.add('hidden');
            });
            document.getElementById('view-' + view).classList.remove('hidden');
        }
    </script>
</body>
</html>
